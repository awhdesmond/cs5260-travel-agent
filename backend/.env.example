# ============================================================
# CS5260 Travel Agent Backend - Environment Variables
# ============================================================
# Copy this file to .env:  cp .env.example .env
# All shared keys are pre-filled — ready to use as-is.
# ============================================================

# === Gemini API (from aistudio.google.com > API keys) ===
GOOGLE_API_KEY=

# === Postgres Database (shared GCE instance) ===
DATABASE_URL=

# === JWT Secret ===
JWT_SECRET=your-jwt-secret-here

# === Token Budget Cap ===
PER_REQUEST_TOKEN_CAP=8000

# === LangSmith Tracing (from smith.langchain.com) ===
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# === SerpAPI Google Flights (https://serpapi.com/) ===
# Real Google Flights data for international flight search
# If not set, falls back to Gemini grounding
SERPAPI_KEY=

# === Google Maps Places API (Essentials SKU) ===
USE_GOOGLE_PLACES=true
GOOGLE_MAPS_API_KEY=
